rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // activity_feed: `ts` vine din FieldValue.serverTimestamp() — nu folosi == request.time
    // (diferențe de ordin micro/milisecunde resping scrierea altfel validă).
    function activityFeedEventTsPlausible() {
      return request.resource.data.ts is timestamp
        && request.resource.data.ts <= request.time + duration.value(2, 'm')
        && request.resource.data.ts >= request.time - duration.value(2, 'm');
    }

    // ── Trial transport (7 zile de la cont Auth; excepții + unlimited) ───────
    // Sursă timp: users/{uid}.trialEndsAt setat de Cloud Function (auth.onCreate + callable).
    function trialUserDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }
    function trialAppConfigPath() {
      return /databases/$(database)/documents/app_config/trial;
    }
    function isTrialBuiltinExemptEmail() {
      return request.auth.token.email != null && (
        request.auth.token.email == 'operatii.77@gmail.com' ||
        request.auth.token.email == 'operatii.777@gmail.com' ||
        request.auth.token.email == 'operatii.77777@gmail.com'
      );
    }
    function isTrialExemptAppConfigEmail() {
      return isAuthenticated()
        && request.auth.token.email != null
        && exists(trialAppConfigPath())
        && 'exemptEmails' in get(trialAppConfigPath()).data
        && get(trialAppConfigPath()).data.exemptEmails is list
        && request.auth.token.email in get(trialAppConfigPath()).data.exemptEmails;
    }
    function isTrialExemptAppConfigUid() {
      return isAuthenticated()
        && exists(trialAppConfigPath())
        && 'exemptUids' in get(trialAppConfigPath()).data
        && get(trialAppConfigPath()).data.exemptUids is list
        && request.auth.uid in get(trialAppConfigPath()).data.exemptUids;
    }
    function userDocTrialExemptFlag() {
      return exists(trialUserDocPath())
        && 'trialExempt' in get(trialUserDocPath()).data
        && get(trialUserDocPath()).data.trialExempt == true;
    }
    function isTrialExempt() {
      return isTrialBuiltinExemptEmail()
        || isTrialExemptAppConfigEmail()
        || isTrialExemptAppConfigUid()
        || userDocTrialExemptFlag();
    }
    function isUnlimitedWalletPlan() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)/token_wallet/wallet)
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/token_wallet/wallet).data.plan == 'unlimited';
    }
    function userTrialPeriodActive() {
      return exists(trialUserDocPath())
        && 'trialEndsAt' in get(trialUserDocPath()).data
        && request.time < get(trialUserDocPath()).data.trialEndsAt;
    }
    function trialPeriodAllowsRides() {
      return isAuthenticated() && (
        isTrialExempt()
        || isUnlimitedWalletPlan()
        || userTrialPeriodActive()
      );
    }
    function userOwnerTrialFieldsUnchanged() {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return !diff.hasAny(['trialEndsAt', 'trialAnchorSource', 'trialExempt']);
    }

    // Reper personal pe hartă (orientare): GeoPoint + etichetă opțională — doar validare tip/lungime.
    function userOwnerMapOrientationFieldsValid() {
      let d = request.resource.data;
      return (!('mapOrientationPin' in d) || d.mapOrientationPin is latlng)
        && (!('mapOrientationPinLabel' in d)
            || (d.mapOrientationPinLabel is string
                && d.mapOrientationPinLabel.size() <= 100));
    }

    // Catalog abonamente (sincronizat cu PLAN_ALLOWANCE din Cloud Functions + app).
    // Scrieri doar din consolă / script; app citește pentru UI și prețuri.
    match /subscription_plans/{planId} {
      allow get:    if isAuthenticated();
      allow list:   if isAuthenticated();
      allow create, update, delete: if false;
    }

    // Batch offers — creat de client la pasagerul cursei principale (rides[0]); citire șofer țintă sau pasageri din listă.
    match /batch_offers/{offerId} {
      allow get, list: if isAuthenticated() && batchOfferUserCanRead();
      allow create: if isAuthenticated() && batchOfferCreateValid()
        && trialPeriodAllowsRides();
      allow update, delete: if false;
    }

    // Verifică dacă utilizatorul curent este pasager SAU șofer al unei curse.
    // Folosit în subcollecții unde nu avem direct datele parentului.
    function isRideParticipant(rideId) {
      let ride = get(/databases/$(database)/documents/ride_requests/$(rideId)).data;
      return request.auth.uid == ride.passengerId
          || request.auth.uid == ride.driverId;
    }

    // Oferte batch (mai multe curse pending) — create din app la pasager; target șofer în document.
    function batchOfferRidePassengerMatches(rideId) {
      return rideId is string
        && exists(/databases/$(database)/documents/ride_requests/$(rideId))
        && get(/databases/$(database)/documents/ride_requests/$(rideId)).data.passengerId == request.auth.uid;
    }
    function batchOfferPassengerInRides(rides, idx) {
      return rides.size() > idx
        && rides[idx].keys().hasAll(['rideId'])
        && batchOfferRidePassengerMatches(rides[idx].rideId);
    }
    function batchOfferUserCanRead() {
      let d = resource.data;
      return d.keys().hasAll(['driverId', 'rides', 'status'])
        && d.driverId == request.auth.uid
        || (d.rides is list && (
          batchOfferPassengerInRides(d.rides, 0)
          || (d.rides.size() > 1 && batchOfferPassengerInRides(d.rides, 1))
          || (d.rides.size() > 2 && batchOfferPassengerInRides(d.rides, 2))
          || (d.rides.size() > 3 && batchOfferPassengerInRides(d.rides, 3))
          || (d.rides.size() > 4 && batchOfferPassengerInRides(d.rides, 4))
        ));
    }
    function batchOfferCreateValid() {
      let r = request.resource.data.rides;
      return request.resource.data.keys().hasAll(['id', 'driverId', 'rides', 'status', 'createdAt', 'expiresAt'])
        && request.resource.data.driverId is string
        && request.resource.data.status == 'pending'
        && r is list
        && r.size() >= 2
        && r[0].keys().hasAll(['rideId'])
        && batchOfferRidePassengerMatches(r[0].rideId);
    }

    // Chat sub-colectare ride_requests: mesaj creat apoi actualizat (livrare/citit/reacții/edit/traducere).
    function rideChatMessageUpdateAllowed(rideId) {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return isRideParticipant(rideId)
        && request.resource.data.senderId == resource.data.senderId
        && (
          (resource.data.senderId == request.auth.uid
            && diff.hasOnly(['deliveredAt', 'status']))
          || (resource.data.senderId != request.auth.uid
            && diff.hasOnly(['readAt', 'status']))
          || (resource.data.senderId == request.auth.uid
            && diff.hasOnly(['text', 'editedAt', 'isEdited']))
          || diff.hasOnly(['translatedText'])
          || diff.hasOnly(['reactions'])
        );
    }

    // Test harness: setează custom claim `test_harness: true` doar în staging (Admin SDK).
    function isTestDriverUser(driverId) {
      return exists(/databases/$(database)/documents/users/$(driverId)) &&
        get(/databases/$(database)/documents/users/$(driverId)).data.isTestAccount == true;
    }

    function isRestaurantOwner(restaurantId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;
    }

    function isDeliveryParticipant() {
      return isAuthenticated() &&
        (request.auth.uid == resource.data.customerId ||
         request.auth.uid == resource.data.courierId ||
         request.auth.uid == resource.data.restaurantOwnerId);
    }

    function isCourier(courierId) {
      return isAuthenticated() &&
        request.auth.uid == courierId;
    }

    // Proprietarul anunțului = userId din business_profiles pentru businessId-ul ofertei.
    function isBusinessOfferOwner() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/business_profiles/$(resource.data.businessId))
        && get(/databases/$(database)/documents/business_profiles/$(resource.data.businessId)).data.userId
          == request.auth.uid;
    }

    // magic_events: business_profiles/{businessId}.userId == request.auth.uid
    function isMagicEventProfileOwner(businessId) {
      return isAuthenticated()
        && businessId is string
        && exists(/databases/$(database)/documents/business_profiles/$(businessId))
        && get(/databases/$(database)/documents/business_profiles/$(businessId)).data.userId
          == request.auth.uid;
    }

    // Doar număr de vizualizări (increment din app pentru orice user autentificat).
    function isBusinessOfferViewIncrementOnly() {
      return isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount'])
        && request.resource.data.viewsCount is int
        && (
          !resource.data.keys().hasAny(['viewsCount'])
          || request.resource.data.viewsCount >= resource.data.viewsCount
        );
    }

    // Portofel: doar creare inițială „free” sau update de tip consum (sold ↓ sau unlimited + totalSpent↑).
    function tokenWalletInitialCreateValid() {
      return request.resource.data.keys().hasAll(
          ['balance', 'totalEarned', 'totalSpent', 'plan', 'resetAt', 'createdAt', 'freeMonthlyAllowance'])
        && request.resource.data.totalSpent == 0
        && request.resource.data.plan == 'free'
        && request.resource.data.balance == request.resource.data.freeMonthlyAllowance
        && request.resource.data.totalEarned == request.resource.data.balance
        && request.resource.data.freeMonthlyAllowance == 1000
        && request.resource.data.balance == 1000;
    }

    function tokenWalletSpendValid() {
      let oldB = resource.data.balance;
      let newB = request.resource.data.balance;
      let oldS = resource.data.totalSpent;
      let newS = request.resource.data.totalSpent;
      let plan = resource.data.plan;
      return request.resource.data.plan == plan
        && request.resource.data.resetAt == resource.data.resetAt
        && request.resource.data.freeMonthlyAllowance == resource.data.freeMonthlyAllowance
        && request.resource.data.totalEarned == resource.data.totalEarned
        && request.resource.data.createdAt == resource.data.createdAt
        && newS >= oldS
        && newB >= 0
        && (
          (plan == 'unlimited' && newB == oldB)
          || (plan != 'unlimited'
              && oldB - newB == newS - oldS
              && newB <= oldB)
        );
    }

    function isRidesCollectionParticipant(rid) {
      let r = get(/databases/$(database)/documents/rides/$(rid)).data;
      return request.auth.uid == r.passengerId || request.auth.uid == r.driverId;
    }

    // ── Ride broadcast helpers (oferte / răspunsuri / reacții) ─────────────
    function rideBroadcastIsPassenger() {
      return isAuthenticated() && resource.data.passengerId == request.auth.uid;
    }

    function rideBroadcastIsAcceptedDriver() {
      return isAuthenticated()
        && 'acceptedDriverId' in resource.data
        && resource.data.acceptedDriverId == request.auth.uid;
    }

    function rideBroadcastInAudience() {
      return isAuthenticated()
        && 'allowedUids' in resource.data
        && request.auth.uid in resource.data.allowedUids;
    }

    function rideBroadcastEngagementOnly() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['offers'])
        || changed.hasOnly(['replies'])
        || changed.hasOnly(['reactions']);
    }

    // ── ride_requests: whitelist câmpuri (client / FirestoreService) + tranziții status
    function rideTerminalStatus(s) {
      return s in ['completed', 'cancelled', 'expired'];
    }
    function rideStatusTransitionValid() {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      let o = resource.data.status;
      let n = request.resource.data.status;
      return !diff.hasAny(['status'])
        || o == n
        || (!rideTerminalStatus(o) && (
          (o == 'pending' && n in ['driver_found', 'expired', 'cancelled', 'searching'])
          || (o == 'searching' && n in ['driver_found', 'pending', 'cancelled', 'expired'])
          || (o == 'driver_found' && n in ['pending', 'accepted', 'cancelled', 'expired'])
          || (o == 'accepted' && n in ['arrived', 'in_progress', 'completed', 'cancelled'])
          || (o == 'arrived' && n in ['in_progress', 'completed', 'cancelled'])
          || (o == 'in_progress' && n in ['completed', 'cancelled'])
        ));
    }
    function rideRequestUpdateKeysAllowed() {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      return diff.hasOnly([
        'acceptedAt', 'aiConversationData', 'aiSessionId', 'appCommission', 'assignedAt',
        'assignmentMethod', 'allowedDriverUids', 'baseFare', 'cancellationFee', 'cancelledAt',
        'cancelledBy', 'cancelledReason', 'category', 'declinedAt', 'declinedBy',
        'destination', 'destinationAddress', 'destinationLatitude', 'destinationLongitude',
        'destinationUpdatedAt', 'distance', 'driverAcceptanceStatus', 'driverAcceptanceUpdatedAt',
        'driverAssignedAt', 'driverCharacterizationForPassenger', 'driverComment', 'driverDistance',
        'driverEarnings', 'driverId', 'driverRating', 'driverRatingForPassenger',
        'driverStatusUpdatedAt', 'driverTimeoutAt', 'durationInMinutes', 'estimatedPrice', 'id',
        'isVoiceRequest', 'numberOfPassengers', 'passengerComment', 'passengerDeclinedDrivers',
        'passengerId', 'passengerNotes', 'passengerRating', 'paymentMethod', 'perKmRate',
        'perMinRate', 'pickupCode', 'pickupLatitude', 'pickupLocation', 'pickupLongitude',
        'ridePreferences', 'routePreviewUrl', 'searchRadius', 'searchStartTime', 'startAddress',
        'startLatitude', 'startLongitude', 'status', 'stops', 'systemLogs', 'timestamp', 'tip',
        'totalCost', 'typing', 'urgency', 'waitStartedAt', 'waitTimeFee', 'wasCancelled',
      ]);
    }
    function rideRequestParticipantUpdateBase() {
      return isAuthenticated()
        && request.resource.data.passengerId == resource.data.passengerId
        && rideRequestUpdateKeysAllowed()
        && rideStatusTransitionValid()
        && (
          resource.data.passengerId == request.auth.uid ||
          resource.data.driverId == request.auth.uid ||
          (resource.data.driverId == null && request.resource.data.driverId == request.auth.uid)
        );
    }
    function rideRequestUpdateAllowed() {
      return rideRequestParticipantUpdateBase()
        || (request.auth.token.test_harness == true
          && (resource.data.passengerId == request.auth.uid
            || resource.data.driverId == request.auth.uid
            || resource.data.driverId == null));
    }

    // Rating agregat pe users/{driverId} / users/{passengerId} — doar dacă media și totalRides
    // respectă formula din cursă și rideId nu e reluat (anti-replay).
    function userNumAt(data, field, defaultVal) {
      return field in data && data[field] is number ? data[field] : defaultVal;
    }
    function userRatingReplayOk() {
      let rid = request.resource.data.rideId;
      return rid is string
        && (!resource.data.keys().hasAny(['rideId']) || resource.data.rideId != rid);
    }
    function floatTolEq(a, b) {
      let d = a - b;
      return d * d < 0.000001;
    }
    function userDriverAggregateFromPassengerRating(userId) {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      let rid = request.resource.data.rideId;
      return diff.hasOnly(['totalRides', 'averageRating', 'rideId'])
        && userRatingReplayOk()
        && rid is string
        && exists(/databases/$(database)/documents/ride_requests/$(rid))
        && get(/databases/$(database)/documents/ride_requests/$(rid)).data.passengerId == request.auth.uid
        && get(/databases/$(database)/documents/ride_requests/$(rid)).data.driverId == userId
        && !(get(/databases/$(database)/documents/ride_requests/$(rid)).data.status in ['cancelled', 'expired'])
        && 'passengerRating' in get(/databases/$(database)/documents/ride_requests/$(rid)).data
        && get(/databases/$(database)/documents/ride_requests/$(rid)).data.passengerRating is number
        && userNumAt(request.resource.data, 'totalRides', -1)
          == userNumAt(resource.data, 'totalRides', 0) + 1
        && floatTolEq(
          request.resource.data.averageRating * request.resource.data.totalRides,
          userNumAt(resource.data, 'averageRating', 0.0) * userNumAt(resource.data, 'totalRides', 0.0)
            + get(/databases/$(database)/documents/ride_requests/$(rid)).data.passengerRating
        );
    }
    function userPassengerAggregateFromDriverRating(userId) {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      let rid = request.resource.data.rideId;
      let newC = userNumAt(request.resource.data, 'totalRidesAsPassenger', -1);
      let oldC = userNumAt(resource.data, 'totalRidesAsPassenger', 0);
      return rid is string
        && userRatingReplayOk()
        && exists(/databases/$(database)/documents/ride_requests/$(rid))
        && get(/databases/$(database)/documents/ride_requests/$(rid)).data.driverId == request.auth.uid
        && get(/databases/$(database)/documents/ride_requests/$(rid)).data.passengerId == userId
        && !(get(/databases/$(database)/documents/ride_requests/$(rid)).data.status in ['cancelled', 'expired'])
        && 'driverRatingForPassenger' in get(/databases/$(database)/documents/ride_requests/$(rid)).data
        && get(/databases/$(database)/documents/ride_requests/$(rid)).data.driverRatingForPassenger is number
        && newC == oldC + 1
        && (
          (diff.hasOnly(['totalRidesAsPassenger', 'rideId', 'passengerAverageRating'])
            && 'passengerAverageRating' in request.resource.data
            && floatTolEq(
              request.resource.data.passengerAverageRating * newC,
              userNumAt(resource.data, 'passengerAverageRating', 0.0) * oldC
                + get(/databases/$(database)/documents/ride_requests/$(rid)).data.driverRatingForPassenger
            ))
          || (diff.hasOnly(['totalRidesAsPassenger', 'rideId', 'passengerAverageRating', 'lastCharacterization'])
            && 'passengerAverageRating' in request.resource.data
            && floatTolEq(
              request.resource.data.passengerAverageRating * newC,
              userNumAt(resource.data, 'passengerAverageRating', 0.0) * oldC
                + get(/databases/$(database)/documents/ride_requests/$(rid)).data.driverRatingForPassenger
            ))
          || diff.hasOnly(['totalRidesAsPassenger', 'rideId', 'lastCharacterization'])
        );
    }

    // ── Users ──────────────────────────────────────────────────────────────
    // Profilurile utilizatorilor trebuie să fie vizibile pentru afișarea
    // numelor și pentru query-ul de număr de telefon în chat.
    // Câmpuri top-level (merge din app): selectedCarAvatarId (legacy),
    // selectedCarAvatarIdDriver / selectedCarAvatarIdPassenger (Galaxy Garage).
    match /users/{userId} {
      allow get:    if isAuthenticated();
      allow list:   if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId)
        && !request.resource.data.keys().hasAny(['trialEndsAt', 'trialAnchorSource', 'trialExempt'])
        && userOwnerMapOrientationFieldsValid();
      allow update: if isAuthenticated() && (
        (isOwner(userId)
          && userOwnerTrialFieldsUnchanged()
          && userOwnerMapOrientationFieldsValid())
        || userDriverAggregateFromPassengerRating(userId)
        || userPassengerAggregateFromDriverRating(userId)
      );
      allow delete: if false;

      // Metode de plată — doar proprietarul
      match /payment_methods/{methodId} {
        allow read, write, delete: if isAuthenticated() && isOwner(userId);
      }

      // Vouchere — doar proprietarul
      match /vouchers/{voucherId} {
        allow read, write, delete: if isAuthenticated() && isOwner(userId);
      }

      // Token wallet — client: doar creare inițială + consum (deduceri). Creșteri: Cloud Functions.
      match /token_wallet/{doc} {
        allow read:   if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId)
          && tokenWalletInitialCreateValid();
        allow update: if isAuthenticated() && isOwner(userId)
          && tokenWalletSpendValid();
        allow delete: if false;
      }

      // Token transactions — log de audit, append-only
      match /token_transactions/{txId} {
        allow read:          if isAuthenticated() && isOwner(userId);
        allow create:        if isAuthenticated() && isOwner(userId);
        allow update, delete: if false;
      }

      // Adrese salvate
      match /saved_addresses/{addressId} {
        allow read, write, delete: if isAuthenticated() && isOwner(userId);
      }

      // Avataruri cumpărate (shop mașini) — doar proprietarul
      match /purchased_avatars/{avatarId} {
        allow read, write, delete: if isAuthenticated() && isOwner(userId);
      }

      // Prieteni acceptați (cerere acceptată): fiecare user își menține lista sub propriul UID.
      // La accept, destinatarul creează doc-ul său; expeditorul își sincronizează la următoarea deschidere app.
      //
      // Citire (get/list) pentru orice user autentificat: necesară pentru căutarea pe hartă /
      // Sugestii — calcul „prieteni în comun” (intersecție friend_peers). Documentele conțin
      // în principal peerUid + since; profilul users/{id} este deja citibil la fel.
      match /friend_peers/{peerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isOwner(userId)
          && peerId == request.resource.data.peerUid
          && request.resource.data.peerUid != userId;
        allow update: if isAuthenticated() && isOwner(userId)
          && resource.data.peerUid == peerId
          && request.resource.data.peerUid == resource.data.peerUid;
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // Explorări — celule explorate (clasament / sync); nume colecție istoric scratch_map_tiles.
      match /scratch_map_tiles/{tileId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() && isOwner(userId);
        allow delete: if false;
      }

      // Mystery Box — înregistrări business: create doar backend; ștergere din istoric de către utilizator.
      match /opened_mystery_boxes/{boxId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if false;
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // Ascundere din ecranul „Activitate cutii” (cutii comunitare rămân în colecția globală).
      match /hidden_community_placed_boxes/{boxId} {
        allow read, create, delete: if isAuthenticated() && isOwner(userId);
        allow update: if false;
      }
      match /hidden_community_claim_boxes/{boxId} {
        allow read, create, delete: if isAuthenticated() && isOwner(userId);
        allow update: if false;
      }
    }

    // ── Ride Requests ──────────────────────────────────────────────────────
    // • Cursele cu status 'pending' trebuie vizibile șoferilor disponibili
    //   (pentru a le accepta). Toate celelalte câmpuri rămân private.
    // • Update-ul fără driverId setat (acceptare cursă) este permis oricărui
    //   user autentificat — driver-ul se "auto-asignează".
    match /ride_requests/{rideId} {
      allow get: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId    == request.auth.uid ||
        resource.data.status      == 'pending'
      );
      allow list: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId    == request.auth.uid ||
        resource.data.status      == 'pending'
      );
      // Doar pasagerul poate crea o cursă pe cont propriu
      allow create: if isAuthenticated() &&
        request.resource.data.passengerId == request.auth.uid
        && trialPeriodAllowsRides();
      // Participanți + whitelist câmpuri + tranziții status; test_harness pentru integrări.
      allow update: if rideRequestUpdateAllowed()
        && (
          trialPeriodAllowsRides()
          || resource.data.passengerId == request.auth.uid
          || resource.data.driverId == request.auth.uid
        );
      // Doar pasagerul poate anula/șterge
      allow delete: if isAuthenticated() &&
        resource.data.passengerId == request.auth.uid;

      // Chat în cursă — acces strict limitat la participanți
      match /chat/{messageId} {
        allow read: if isAuthenticated() && isRideParticipant(rideId);
        allow create: if isAuthenticated() && isRideParticipant(rideId)
          && request.resource.data.senderId == request.auth.uid;
        allow update: if rideChatMessageUpdateAllowed(rideId);
        allow delete: if false;
      }
    }

    // ── Driver locations ───────────────────────────────────────────────────
    // Locațiile GPS în timp real ale șoferilor sunt vizibile tuturor
    // utilizatorilor autentificați (necesare pentru harta de disponibilitate).
    // Write: doar proprietarul sau contul de test.
    match /driver_locations/{driverId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated() && (
        (isOwner(driverId) && trialPeriodAllowsRides()) ||
        (request.auth.token.test_harness == true && isTestDriverUser(driverId))
      );
    }

    // ── Drivers ────────────────────────────────────────────────────────────
    match /drivers/{driverId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(driverId) && trialPeriodAllowsRides();
    }

    // ── Driver applications ────────────────────────────────────────────────
    match /driver_applications/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // ── Driver incentives ──────────────────────────────────────────────────
    match /driver_incentives/{incentiveId} {
      allow read:                  if isAuthenticated();
      allow create, update, delete: if false; // Only admin/backend
    }

    // ── Ride history ───────────────────────────────────────────────────────
    // Istoricul este read-only din client; scrisul se face prin backend/CF.
    // Participanții pot citi propriile curse; nimeni nu poate șterge.
    match /ride_history/{rideId} {
      allow get: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId    == request.auth.uid
      );
      allow list: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId    == request.auth.uid
      );
      // Permite write din app (cursele se finalizează din client)
      // dar doar participantul curent poate crea/actualiza
      allow create: if isAuthenticated() && (
        request.resource.data.passengerId == request.auth.uid ||
        request.resource.data.driverId    == request.auth.uid
      )
        && trialPeriodAllowsRides();
      allow update: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId    == request.auth.uid
      );
      allow delete: if false;
    }

    // ── Chat messages (colecție globală legacy) ────────────────────────────
    // Restricționat la expeditor; mesajele nu pot fi modificate sau șterse.
    match /chat_messages/{messageId} {
      allow read:   if isAuthenticated() &&
        resource.data.senderId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Support tickets ────────────────────────────────────────────────────
    match /support_tickets/{ticketId} {
      allow read:   if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      // Utilizatorul poate actualiza propriul ticket (adăugare info)
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── Payment methods (colecție globală — delivery/merchant) ─────────────
    // Dacă documentul nu are câmpul userId, regula de mai jos va nega accesul.
    // Mutați datele în /users/{userId}/payment_methods dacă este posibil.
    match /payment_methods/{methodId} {
      allow read, update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
    }

    // ── Vouchers (colecție globală — delivery/merchant) ────────────────────
    match /vouchers/{voucherId} {
      allow read, update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
    }

    // ── Business profile requests ──────────────────────────────────────────
    match /business_profile_requests/{requestId} {
      allow read:   if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if false;
    }

    // ── Referral codes ─────────────────────────────────────────────────────
    // Update-ul era deschis oricărui user → fraud. Acum doar backend-ul poate
    // modifica contoarele de utilizare (update: if false).
    match /referral_codes/{codeId} {
      allow read:                  if isAuthenticated();
      allow create, update, delete: if false; // Only admin/backend
    }

    // ── Social map ─────────────────────────────────────────────────────────
    // Include carAvatarId (ID avatar garaj publicat pentru vecini, RTDB + FS).
    match /user_visible_locations/{userId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId) && trialPeriodAllowsRides();
    }

    // ── Neighborhood chat — nb_room = index H3 (string), setat de nabourSyncNeighborhoodRoom.
    match /neighborhood_chats/{roomId}/messages/{msgId} {
      allow read:   if isAuthenticated()
        && request.auth.token.nb_room == roomId;
      allow create: if isAuthenticated()
        && request.auth.token.nb_room == roomId
        && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated()
        && request.auth.token.nb_room == roomId
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && request.auth.token.nb_room == roomId
        && resource.data.uid == request.auth.uid;
    }

    // Config doar-citire (ex. trial exemptions) — scris din Console / Admin SDK.
    match /app_config/{docId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // ── Cereri cartier (bule pe hartă) — create autor; orice vecin poate marca resolved ──
    match /neighborhood_requests/{reqId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.resolved == false
        && request.resource.data.resolved == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resolved']);
      allow delete: if isAuthenticated()
        && resource.data.authorUid == request.auth.uid;
    }

    // ── Ride broadcasts ────────────────────────────────────────────────────
    match /ride_broadcasts/{broadcastId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.passengerId == request.auth.uid
        && trialPeriodAllowsRides();
      // Pasagerul: orice actualizare. Șoferul acceptat: confirmări / status cursă.
      // Membrii din allowedUids: doar oferte, răspunsuri, reacții (arrayUnion etc.).
      allow update: if (rideBroadcastIsPassenger()
        || rideBroadcastIsAcceptedDriver()
        || (rideBroadcastInAudience() && rideBroadcastEngagementOnly()))
        && (
          trialPeriodAllowsRides()
          || rideBroadcastIsPassenger()
          || rideBroadcastIsAcceptedDriver()
        );
      allow delete: if isAuthenticated()
        && resource.data.passengerId == request.auth.uid;

      // Chat-ul unui broadcast
      match /messages/{messageId} {
        allow read, write: if isAuthenticated()
          && (request.auth.uid in broadcastId.split('_'));
      }
    }

    // ── Private chats ──────────────────────────────────────────────────────
    match /private_chats/{chatId} {
      allow read, write: if isAuthenticated()
        && (request.auth.uid in chatId.split('_'));

      match /messages/{messageId} {
        allow read, write: if isAuthenticated()
          && (request.auth.uid in chatId.split('_'));
      }

      match /_chat/{doc} {
        allow read, write: if isAuthenticated()
          && (request.auth.uid in chatId.split('_'));
      }
    }

    // ── Rides (tracking / comunicări) — nu folosi ride_requests ca părinte pentru sub-colecții.
    match /rides/{rideId} {
      allow get, list: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId    == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        request.resource.data.passengerId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      )
        && trialPeriodAllowsRides();
      allow update: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId    == request.auth.uid
      );
      allow delete: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId    == request.auth.uid
      );

      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && isRidesCollectionParticipant(rideId);
      }
      match /_chat/{doc} {
        allow read, write: if isAuthenticated() && isRidesCollectionParticipant(rideId);
      }
      match /communications/{commId} {
        allow read, create: if isAuthenticated() && isRidesCollectionParticipant(rideId);
        allow update, delete: if false;
      }
    }

    // ── Urgențe (tracking AI / siguranță) ───────────────────────────────────
    match /emergencies/{emergencyId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update, delete: if false;
    }

    // ── SOS / alerte geografice (MapScreen snapshot + Safety + FirebaseService) ──
    // Client: list query folosește where('status','==','active') — trebuie să coincidă cu regula.
    match /emergency_alerts/{alertId} {
      allow read: if isAuthenticated()
        && resource.data.status == 'active';
      allow create: if isAuthenticated()
        && (
          request.resource.data.userId == request.auth.uid
          || request.resource.data.reporterId == request.auth.uid
        );
      allow update, delete: if false;
    }

    // ── Safe Ride tracking — link public read; scriere doar de către creator (createdByUid).
    match /safe_rides/{token} {
      allow read:   if true;
      allow create: if isAuthenticated()
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.createdByUid == request.auth.uid;
      allow delete: if false;
    }

    // ── Parking Swap (crowdsourced utility) ────────────────────────────────
    match /parking_swap_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.providerId == request.auth.uid
        && request.resource.data.status == 'available';
      allow update: if isAuthenticated() && (
        // 1. Oricine poate marca 'expired' dacă timpul a trecut (maintenance)
        (request.resource.data.status == 'expired' && resource.data.status == 'available'
         && request.time > resource.data.expiresAt)
        ||
        // 2. Un claimer (căutător) rezervă locul
        (resource.data.status == 'available' && request.resource.data.status == 'reserved'
         && request.resource.data.claimerId == request.auth.uid)
        ||
        // 3. Finalizare: cel care a rezervat confirmă 'claimed'
        (resource.data.status == 'reserved' && request.resource.data.status == 'claimed'
         && resource.data.claimerId == request.auth.uid)
      );
      allow delete: if false;
    }

    // ── Business profiles ──────────────────────────────────────────────────
    match /business_profiles/{profileId} {
      allow read:          if isAuthenticated();
      allow create:        if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ── Business offers ────────────────────────────────────────────────────
    match /business_offers/{offerId} {
      allow read:   if isAuthenticated();
      // mysteryBoxClaimed doar din Cloud Function (client: doar 0 la creare)
      allow create: if isAuthenticated()
        && (!('mysteryBoxClaimed' in request.resource.data)
            || request.resource.data.mysteryBoxClaimed == 0)
        && (!('mysteryBoxTotal' in request.resource.data)
            || (request.resource.data.mysteryBoxTotal is int
                && request.resource.data.mysteryBoxTotal > 0
                && request.resource.data.mysteryBoxTotal <= 100000));
      allow update: if isBusinessOfferViewIncrementOnly()
        || (isBusinessOfferOwner()
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['mysteryBoxClaimed']));
      allow delete: if false;
    }

    // Magic Event Check-in (geofence): participantCount doar server-side ulterior.
    match /magic_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isMagicEventProfileOwner(request.resource.data.businessId)
        && (!('participantCount' in request.resource.data)
            || request.resource.data.participantCount == 0);
      allow update: if isMagicEventProfileOwner(resource.data.businessId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participantCount']);
      allow delete: if isMagicEventProfileOwner(resource.data.businessId);
    }

    match /magic_events/{eventId}/participants/{participantUid} {
      allow read: if isAuthenticated();
      allow create, update: if false;
      // Proprietarul evenimentului poate șterge înregistrări (curățare la ștergere eveniment).
      allow delete: if isAuthenticated()
        && exists(/databases/$(database)/documents/magic_events/$(eventId))
        && isMagicEventProfileOwner(
          get(/databases/$(database)/documents/magic_events/$(eventId)).data.businessId
        );
    }

    // Coduri provizorii Mystery Box — doar Cloud Functions (claim + validare comerciant).
    match /mystery_box_redemptions/{code} {
      allow read, write: if false;
    }

    // Mystery Box comunitar (plasare + claim doar prin Functions).
    match /community_mystery_boxes/{boxId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /users/{userId}/community_mystery_notifications/{eventId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if false;
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // ── DELIVERY ───────────────────────────────────────────────────────────

    match /restaurants/{restaurantId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() &&
        (request.resource.data.ownerId == request.auth.uid ||
         request.resource.data.ownerId == null);
      // Update: doar owner-ul restaurantului
      allow update: if isAuthenticated() &&
        resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }

    match /products/{productId} {
      allow read:          if isAuthenticated();
      allow create:        if isAuthenticated() &&
        isRestaurantOwner(request.resource.data.restaurantId);
      allow update:        if isAuthenticated() &&
        isRestaurantOwner(resource.data.restaurantId);
      allow delete:        if isAuthenticated() &&
        isRestaurantOwner(resource.data.restaurantId);
    }

    match /delivery_orders/{orderId} {
      allow read:   if isAuthenticated() && isDeliveryParticipant();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.customerId) ||
        isCourier(resource.data.courierId) ||
        isRestaurantOwner(resource.data.restaurantId)
      );
      allow delete: if false;
    }

    match /couriers/{courierId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && isCourier(courierId);
      allow update: if isAuthenticated() && isCourier(courierId);
      allow delete: if false;
    }

    match /restaurant_couriers/{courierId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isCourier(resource.data.courierId) ||
        resource.data.restaurantId != null &&
          isRestaurantOwner(resource.data.restaurantId)
      );
      allow delete: if false;
    }

    // API keys: niciodată citibile din client; create/update doar prin backend.
    match /restaurant_api_keys/{keyId} {
      allow read:                  if false;
      allow create, update, delete: if false;
    }

    match /restaurant_onboarding/{requestId} {
      allow read:   if isAuthenticated() && isOwner(resource.data.ownerId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isOwner(resource.data.ownerId);
      allow delete: if false;
    }

    // ── Map moments (stări efemere pe hartă, ex. 24h) ─────────────────────
    match /map_moments/{momentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
      );
      allow delete: if isAuthenticated() && resource.data.authorUid == request.auth.uid;
    }

    // ── Cereri de prietenie (Sugestii prieteni) ────────────────────────────
    match /friend_requests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.status == 'pending';
      allow read: if isAuthenticated() && (
        resource.data.fromUid == request.auth.uid
        || resource.data.toUid == request.auth.uid
      );
      allow update: if isAuthenticated()
        && resource.data.toUid == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'rejected']
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid;
      allow delete: if false;
    }

    // ── Activity feed — activity_feed/{uid}/events (evenimente proprii; prieteni + tu în app) ──
    match /activity_feed/{userId} {
      match /events/{eventId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isOwner(userId)
          && request.resource.data.type is string
          && request.resource.data.text is string
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.actorName is string
          && activityFeedEventTsPlausible()
          && (!('lat' in request.resource.data)
              || request.resource.data.lat is number)
          && (!('lng' in request.resource.data)
              || request.resource.data.lng is number);
        // pruneOldEvents() șterge intrări vechi; doar proprietarul feed-ului.
        allow delete: if isAuthenticated() && isOwner(userId);
        allow update: if false;
      }
    }

    // ── Map Emojis (transient reactions) ──────────────────────────────────
    // TTL: în Firebase Console / `firestore.indexes.json` — câmp `expireAt` (ștergere ~30 min).
    match /map_emojis/{emojiId} {
      // expireAt trebuie să fie după timestamp (TTL ~30 min din app); evităm ferestre strânse 15–45m
      // care pot respinge scrieri valide în funcție de motorul de reguli / precizie.
      function validMapEmojiExpiry() {
        let ts = request.resource.data.timestamp;
        let ex = request.resource.data.expireAt;
        return ts is timestamp
          && ex is timestamp
          && ex > ts
          && ex <= ts + duration.value(2, 'h');
      }
      function mapEmojiCoreFieldsOk() {
        return request.resource.data.senderId == request.auth.uid
          && request.resource.data.senderId == emojiId
          && request.resource.data.emoji is string
          && request.resource.data.lat is number
          && request.resource.data.lng is number;
      }
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
        && mapEmojiCoreFieldsOk()
        && validMapEmojiExpiry();
      allow update: if isAuthenticated()
        && emojiId == request.auth.uid
        && mapEmojiCoreFieldsOk()
        && (!resource.exists
            || !('senderId' in resource.data)
            || resource.data.senderId == request.auth.uid)
        && validMapEmojiExpiry();
      // Doc id = senderId (uid). Permite ștergere idempotentă chiar dacă doc-ul nu mai există
      // (TTL / cache) sau are doc vechi fără câmp senderId — altfel clientul primește permission-denied.
      allow delete: if isAuthenticated() && emojiId == request.auth.uid;
    }

    // ── Default deny ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Token Transfer: portofel transferabil ──────────────────────────────
    // Balanța e modificată exclusiv din Cloud Functions (Admin SDK).
    match /token_wallets/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false;
    }

    // ── Token Transfer: transferuri directe ────────────────────────────────
    match /token_direct_transfers/{transferId} {
      allow read: if isAuthenticated() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId   == request.auth.uid
      );
      allow write: if false;
    }

    // ── Token Transfer: cereri de plată ────────────────────────────────────
    match /token_payment_requests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.payerId == request.auth.uid ||
        resource.data.payeeId == request.auth.uid
      );
      allow write: if false;
    }

    // ── Token Transfer: jurnal de audit ────────────────────────────────────
    match /token_ledger/{entryId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
