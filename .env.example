# ═══════════════════════════════════════════════════════════
#  Nabour — șablon de configurare
#  Copiază acest fișier: cp .env.example .env
#  Completează cu cheile tale și NU îl comite în git.
# ═══════════════════════════════════════════════════════════

# ── Mapbox (obligatoriu pentru hartă) ───────────────────────
# Obține gratuit: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=pk.REPLACE_WITH_YOUR_MAPBOX_TOKEN
MAPBOX_SECRET_TOKEN=

# ── AI Providers (opțional — fără ele asistentul vocal e dezactivat) ──
# Cerebras — cel mai rapid și ieftin (~$0.10/M tokens)
# Obține cheie gratuită: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Google Gemini — fallback AI
# Obține cheie gratuită: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# xAI Grok — fallback secundar
# Obține cheie: https://console.x.ai
GROK_API_KEY=

# OpenAI (rezervat pentru viitor)
OPENAI_API_KEY=

# ── Firebase ─────────────────────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=nabour-4b4e4

# ── Sentry error tracking (opțional) ────────────────────────
SENTRY_DSN=

# ── Feature flags ────────────────────────────────────────────
USE_GEMINI_TRANSLATION_FALLBACK=false
USE_GEMINI_FOR_ADVANCED_INTENTS=false
ENABLE_LOCAL_DICTIONARY_TRANSLATION=true
