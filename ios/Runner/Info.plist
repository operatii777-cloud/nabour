<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Friendsride App</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>friendsride_app</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UIStatusBarHidden</key>
		<false/>
		<key>NSCalendarsUsageDescription</key>
		<string>FriendsRide citește calendarul pentru sugestii de cursă legate de întâlniri.</string>
		<key>NSCalendarsFullAccessUsageDescription</key>
		<string>FriendsRide are nevoie de acces la calendar pentru a propune transport la evenimentele tale.</string>
		<key>NSContactsUsageDescription</key>
		<string>FriendsRide accesează contactele pentru apeluri și recomandări rapide.</string>
		<key>LSApplicationQueriesSchemes</key>
		<array>
			<string>whatsapp</string>
			<string>https</string>
			<string>http</string>
		</array>
		<key>NSLocationWhenInUseUsageDescription</key>
		<string>Nabour folosește locația pentru hartă, curse și recomandări.</string>
		<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
		<string>Pentru Timeline și Week in Review putem înregistra deplasările și când aplicația nu e deschisă. Datele rămân stocate local pe telefon.</string>
		<key>UIBackgroundModes</key>
		<array>
			<string>location</string>
		</array>
		<key>NSCameraUsageDescription</key>
		<string>Nabour folosește camera pentru scanarea codurilor Mystery Box la validare.</string>
		<key>NSMicrophoneUsageDescription</key>
		<string>Nabour folosește microfonul pentru mesaje vocale în chatul de cartier și pentru asistentul vocal.</string>
	</dict>
</plist>
