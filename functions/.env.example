# Copiază în `.env` în același folder înainte de `firebase deploy --only functions`
# (CLI non-interactiv cere aceste chei definite, chiar dacă sunt goale).
# true sau gol = permite creditare din app (Mystery Box, top-up simulat). false = doar cu plăți verificate.
ALLOW_UNVERIFIED_WALLET_CREDIT=true
GEMINI_API_KEY=
