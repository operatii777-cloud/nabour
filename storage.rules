rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Participant la mesaj vocal: chat privat uid1_uid2 sau ride_requests.
    // (Fără if/let suplimentar — sintaxa Storage rules e mai strictă decât Firestore rules.)
    function voiceChatParticipant(rideId) {
      let parts = rideId.split('_');
      return (parts.size() == 2
          && parts[0].size() > 0 && parts[1].size() > 0
          && (parts[0] == request.auth.uid || parts[1] == request.auth.uid))
        || (firestore.exists(/databases/(default)/documents/ride_requests/$(rideId))
            && (firestore.get(/databases/(default)/documents/ride_requests/$(rideId)).data.passengerId == request.auth.uid
                || firestore.get(/databases/(default)/documents/ride_requests/$(rideId)).data.driverId == request.auth.uid));
    }

    // Previzualizare traseu cursă — deploy: firebase deploy --only storage
    match /ride_route_previews/{rideId}/preview.png {
      function ridePath() {
        return /databases/(default)/documents/ride_requests/$(rideId);
      }
      function ride() {
        return firestore.get(ridePath()).data;
      }

      allow read: if request.auth != null
        && firestore.exists(ridePath())
        && (ride().passengerId == request.auth.uid || ride().driverId == request.auth.uid);

      // Captura la confirmarea pasagerului — doar pasagerul încarcă.
      allow write: if request.auth != null
        && firestore.exists(ridePath())
        && ride().passengerId == request.auth.uid
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType == 'image/png';
    }

    // Imagini chat cursă (participanți la ride_requests)
    match /ride_requests/{rideId}/chat_media/{fileName} {
      function ridePath() {
        return /databases/(default)/documents/ride_requests/$(rideId);
      }
      function ride() {
        return firestore.get(ridePath()).data;
      }
      allow read: if request.auth != null
        && firestore.exists(ridePath())
        && (ride().passengerId == request.auth.uid || ride().driverId == request.auth.uid);
      allow write: if request.auth != null
        && firestore.exists(ridePath())
        && (ride().passengerId == request.auth.uid || ride().driverId == request.auth.uid)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Imagini chat privat (chatId = uid1_uid2 sortat)
    match /private_chats/{chatId}/chat_media/{fileName} {
      function isPrivateChatMember() {
        let parts = chatId.split('_');
        return parts.size() == 2
          && (parts[0] == request.auth.uid || parts[1] == request.auth.uid);
      }
      allow read: if request.auth != null && isPrivateChatMember();
      allow write: if request.auth != null && isPrivateChatMember()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Fotografii de profil — max 500KB, doar proprietarul poate scrie
    match /profile_images/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName == (request.auth.uid + '.jpg')
        && request.resource.size < 500 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Fotografii mașină — max 1MB, doar proprietarul poate scrie
    match /driver_photos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 1 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Mesaje vocale chat (ride sau chat privat uid1_uid2). Path: voice_messages/{rideId}/timestamp.m4a
    match /voice_messages/{rideId}/{fileName} {
      allow read: if request.auth != null && voiceChatParticipant(rideId);
      allow write: if request.auth != null
        && voiceChatParticipant(rideId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }
  }
}
